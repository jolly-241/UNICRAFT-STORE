# ==========================================
# NEXT.JS ENVIRONMENT VARIABLES CONFIGURATION
# Copy these into your .env.local file
# ==========================================

# 1. HOST DOMAIN URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 2. FIREBASE PUBLIC CLIENT CREDENTIALS
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# 3. SMTP EMAIL SERVICE CONFIGURATION (SERVER-ONLY)
# Configuration for sending transaction confirmation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-outgoing-email-address@gmail.com
SMTP_PASS=your-email-app-password

# 4. MERCHANT SALES RECEIVING EMAIL
# The email address that will receive notification alerts containing payment proof links
MERCHANT_EMAIL=jollyd241@gmail.com
